{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.example.org/hesp/core/categories/assets.json",
  "title": "HESP CORE - Household assets",
  "description": "Ownership and values of liquid accounts, retirement and investment assets, business and property equity, vehicles, valuables, and cash.",
  "type": "object",
  "x-variable-group": "assets",
  "properties": {
    "checking_owned": {
      "$ref": "../../common/defs.json#/$defs/yes_no",
      "title": "Checking account owned"
    },
    "checking_balance": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0,
          "maximum": 50000000
        },
        {
          "$ref": "../../common/defs.json#/$defs/not_applicable"
        },
        {
          "$ref": "../../common/defs.json#/$defs/refused"
        },
        {
          "$ref": "../../common/defs.json#/$defs/dont_know"
        },
        {
          "$ref": "../../common/defs.json#/$defs/not_collected"
        }
      ],
      "title": "Balance or value of checking account",
      "x-universe": "Households owning a checking account.",
      "x-unit": "currency units"
    },
    "savings_owned": {
      "$ref": "../../common/defs.json#/$defs/yes_no",
      "title": "Savings account owned"
    },
    "savings_balance": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0,
          "maximum": 50000000
        },
        {
          "$ref": "../../common/defs.json#/$defs/not_applicable"
        },
        {
          "$ref": "../../common/defs.json#/$defs/refused"
        },
        {
          "$ref": "../../common/defs.json#/$defs/dont_know"
        },
        {
          "$ref": "../../common/defs.json#/$defs/not_collected"
        }
      ],
      "title": "Balance or value of savings account",
      "x-universe": "Households owning a savings account.",
      "x-unit": "currency units"
    },
    "prepaid_account_owned": {
      "$ref": "../../common/defs.json#/$defs/yes_no",
      "title": "Reloadable prepaid or stored-value account owned"
    },
    "prepaid_account_balance": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0,
          "maximum": 5000000
        },
        {
          "$ref": "../../common/defs.json#/$defs/not_applicable"
        },
        {
          "$ref": "../../common/defs.json#/$defs/refused"
        },
        {
          "$ref": "../../common/defs.json#/$defs/dont_know"
        },
        {
          "$ref": "../../common/defs.json#/$defs/not_collected"

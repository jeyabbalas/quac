      "$ref": "../../common/defs.json#/$defs/yes_no",
      "title": "Valuable items held primarily as assets owned"
    },
    "valuables_balance": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0,
          "maximum": 10000000

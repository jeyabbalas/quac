      "x-universe": "Households owning a stocks, bonds, mutual funds, or exchange-traded funds.",
      "x-unit": "currency units"
    },
    "business_owned": {
      "$ref": "../../common/defs.json#/$defs/yes_no",
      "title": "Privately held business owned"
    },
    "business_equity": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": -5000000,
          "maximum": 100000000,
          "not": {
            "enum": [
              -666,
              -777,
              -888,
              -999
            ]
          }
        },
        {
          "$ref": "../../common/defs.json#/$defs/not_applicable"
        },
        {
          "$ref": "../../common/defs.json#/$defs/refused"
        },
        {
          "$ref": "../../common/defs.json#/$defs/dont_know"
        },
        {
          "$ref": "../../common/defs.json#/$defs/not_collected"
        }
      ],

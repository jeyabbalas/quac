  "required": [
    "checking_owned",
    "checking_balance",
    "savings_owned",
    "savings_balance",
    "prepaid_account_owned",
    "prepaid_account_balance",
    "money_market_cd_owned",
    "money_market_cd_balance",
    "retirement_account_owned",
    "retirement_account_balance",
    "stocks_bonds_owned",
    "stocks_bonds_balance",
    "business_owned",
    "business_equity",
    "other_real_estate_owned",
    "other_real_estate_equity",

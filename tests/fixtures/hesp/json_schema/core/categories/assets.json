    "retirement_account_owned": {
      "$ref": "../../common/defs.json#/$defs/yes_no",
      "title": "Employer or individual retirement account owned"
    },
    "retirement_account_balance": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0,
          "maximum": 100000000

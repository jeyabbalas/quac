      "x-universe": "Households owning a employer or individual retirement account.",
      "x-unit": "currency units"
    },
    "stocks_bonds_owned": {
      "$ref": "../../common/defs.json#/$defs/yes_no",
      "title": "Stocks, bonds, mutual funds, or exchange-traded funds owned"

    "rental_income_annual": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": -5000000,
          "maximum": 20000000,
          "not": {
            "enum": [
              -666,
              -777,
              -888,
              -999
            ]
          }
        },
        {
          "$ref": "../../common/defs.json#/$defs/not_applicable"
        },
        {
          "$ref": "../../common/defs.json#/$defs/refused"
        },
        {
          "$ref": "../../common/defs.json#/$defs/dont_know"

    "alimony_received": {
      "$ref": "../../common/defs.json#/$defs/yes_no",
      "title": "Alimony or maintenance received received in reference year"
    },
    "alimony_annual": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000000

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.example.org/hesp/core/categories/income.json",
  "title": "HESP CORE - Household income",
  "description": "Annual household income sources, tax filing, refundable tax credits, and total cash income.",
  "type": "object",
  "x-variable-group": "income",
  "properties": {
    "wage_income_received": {
      "$ref": "../../common/defs.json#/$defs/yes_no",
      "title": "Wages, salaries, commissions, and tips received in reference year"
    },
    "wage_income_annual": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0,
          "maximum": 50000000
        },
        {
          "$ref": "../../common/defs.json#/$defs/not_applicable"
        },
        {
          "$ref": "../../common/defs.json#/$defs/refused"
        },
        {
          "$ref": "../../common/defs.json#/$defs/dont_know"
        },
        {
          "$ref": "../../common/defs.json#/$defs/not_collected"
        }
      ],
      "title": "Annual amount: wages, salaries, commissions, and tips",
      "x-universe": "Households reporting wages, salaries, commissions, and tips.",
      "x-unit": "currency units per year"
    },
    "selfemp_income_received": {
      "$ref": "../../common/defs.json#/$defs/yes_no",
      "title": "Net self-employment income received in reference year"
    },
    "selfemp_income_annual": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": -5000000,
          "maximum": 50000000,
          "not": {
            "enum": [
              -666,
              -777,
              -888,
              -999
            ]
          }
        },
        {
          "$ref": "../../common/defs.json#/$defs/not_applicable"
        },
        {
          "$ref": "../../common/defs.json#/$defs/refused"
        },
        {
          "$ref": "../../common/defs.json#/$defs/dont_know"
        },
        {
          "$ref": "../../common/defs.json#/$defs/not_collected"
        }

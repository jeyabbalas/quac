  "required": [
    "wage_income_received",
    "wage_income_annual",
    "selfemp_income_received",
    "selfemp_income_annual",
    "interest_dividend_received",
    "interest_dividend_annual",
    "retirement_income_received",
    "retirement_income_annual",
    "rental_income_received",
    "rental_income_annual",
    "child_support_received",
    "child_support_annual",
    "alimony_received",
    "alimony_annual",
    "private_transfer_received",
    "private_transfer_annual",
    "other_income_received",
    "other_income_annual",
    "tax_return_filed",
    "tax_filing_status",
    "eitc_received",
    "eitc_amount",
    "child_tax_credit_received",
    "child_tax_credit_amount",
    "total_household_income_annual",
    "income_imputation_flag"
  ],
  "$comment": "Soft check: total_household_income_annual should equal the sum of reported private income, public cash benefits, and refundable credits after harmonization."
}
